---
const { href, ...props } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const resolvedHref = href.startsWith('/') ? `${baseUrl}${href.slice(1)}` : href;

console.log("BASE_URL:", baseUrl);
console.log("Incoming href:", href);


console.log("Resolved:", resolvedHref);


---
<a href={resolvedHref} {...props}>
  <slot />
</a>