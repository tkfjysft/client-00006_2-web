---
import { NAV_ITEMS, SITE_TITLE } from '../data/site';
import * as Lucide from 'lucide-astro';
const getIcon = (name: string) => {
  return Lucide[name as keyof typeof Lucide];
};
---

<header class="fixed w-full h-20 z-50 bg-white/80 backdrop-blur-sm border-b border-base-1">
  <div class="flex items-center justify-between max-w-[1440px] mx-auto py-4 h-20">
    <div class="text-3xl font-serif font-bold text-black-1"><Link href="/">{SITE_TITLE}</Link></div>
    
    <nav class="hidden md:flex gap-8">
      {NAV_ITEMS.map((item) => {
          const Icon = getIcon(item.icon);
          return (
            <Link href={item.url} class="flex items-center gap-2 text-base text-black-1 hover:text-accent-1 transition-colors">
              {Icon && <Icon class="w-4 h-4 text-accent-1" />}
              <span>{item.text}</span>
            </Link>
          );
        })}
    </nav>

    {/* 【魔法のボタン】detailsタグでアコーディオンを実装 */}
    <details class="md:hidden relative">
      <summary class="list-none p-2 text-main-1 cursor-pointer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </summary>
      
      {/* メニューの中身 */}
      <div class="absolute right-0 top-12 w-64 bg-white-1 border border-base-1 p-6 rounded-lg shadow-xl">
        <ul class="flex flex-col gap-4">
          {NAV_ITEMS.map((item) => (
            <li><Link href={item.url} class="block text-lg text-black-1 font-serif">{item.text}</Link></li>
          ))}
        </ul>
      </div>
    </details>
  </div>
</header>