---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.webp';

const heroData = (await getEntry('home', 'hero'))!;
const { heroTitle_A, heroTitle_B, heroSub, heroDescription, buttonText } = heroData.data;
---

<section class="relative w-full h-screen flex items-center justify-center px-6 py-12 bg-base-1 overflow-hidden">

  {/* 装飾コンテナ（背景の円を少し整理） */}
<div class="absolute inset-0 w-full h-full pointer-events-none">
	    <div class="absolute -top-10 -left-10 w-80 h-80 bg-main-1/30 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-35 right-0 w-70 h-70 bg-accent-1/30 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative z-10 w-full max-w-[1200px] flex flex-col md:flex-row items-center gap-16">
    
    {/* テキストエリア */}
    <div class="flex-1 space-y-8">
      <div class="space-y-4">
        <p class="text-main-1 font-serif tracking-widest uppercase text-base font-semibold">{heroSub}</p>
        <h1 class="text-4xl md:text-6xl font-serif leading-[1.2] text-black-1">{heroTitle_A}<span class="text-[40px]" set:html={heroTitle_B} /></h1>
      </div>
      
      <div class="text-black-1/80 leading-relaxed max-w-md" set:html={heroDescription} />
      
      <div class="pt-4">
        <Link href="/contact" class="inline-flex items-center bg-main-1 text-white px-10 py-4 rounded-full shadow-lg hover:shadow-main-1/20 transition-all hover:-translate-y-1">
          {buttonText}
        </Link>
      </div>
    </div>

    {/* 写真エリア（フレーム効果を追加） */}
    <div class="flex-1 w-full relative">
      {/* 写真の背後にアクセントの枠を追加 */}
      <div class="absolute -top-6 -right-6 w-full h-full border border-main-1/20 rounded-3xl -z-10"></div>
      
      <Image 
        src={heroImage} 
        alt="占い風景" 
        class="rounded-3xl shadow-2xl w-full h-auto object-cover max-h-[600px] aspect-[4/5] md:aspect-auto" 
      />
    </div>
  </div>
</section>