---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { OWNER_NAME } from '../data/site';
import SectionContainer from './SectionContainer.astro';

const greetingData = (await getEntry('home', 'greeting'))!;
const content = greetingData.data.content.replace('{NAME}', OWNER_NAME);
const { title } = greetingData.data;
---

<section class="relative py-24 overflow-hidden mt-[50vh]">


  <SectionContainer class="section-margin-y flex flex-col items-center relative z-10">
	  <div class="bg-white/50 backdrop-blur-md border border-white/10 p-6 md:p-8 rounded-3xl shadow-2xl">

    <div class="max-w-3xl space-y-10">
      <h2 class="text-3xl md:text-4xl font-serif text-clr-main-1 tracking-widest uppercase text-center">
        {title}
      </h2>
      
      <div class="max-w-2xl mx-auto space-y-6">
        <p class="text-clr-bl-1 font-serif text-lg md:text-xl leading-loose whitespace-pre-line opacity-90 text-left">
          {content}
        </p>
      </div>

      <div class="flex justify-center pt-4">
        <div class="w-24 h-px bg-clr-main-1"></div>
      </div>
    </div>
</div>
  </SectionContainer>
</section>